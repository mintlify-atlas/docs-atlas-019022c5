  "keyFeatures": [
    "Multi-tenant IoT platform with UUID-based isolation",
    "Real-time MQTT data ingestion from greenhouse sensors",
    "TimescaleDB time-series storage with continuous aggregates",
    "Redis caching for sub-second data retrieval",
    "JWT authentication and role-based access control",
    "WebSocket/STOMP real-time push notifications",
    "Comprehensive REST API with OpenAPI documentation",
    "Kubernetes-ready with StatefulSet deployments",
    "Flyway database migrations with staging infrastructure",
    "Rate limiting and security controls"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login - JWT authentication",
    "POST /api/v1/auth/register - Tenant registration",
    "GET /api/v1/tenants/{tenantId} - Tenant details",
    "GET /api/v1/tenants/{tenantId}/greenhouses - List greenhouses",
    "GET /api/v1/sensors/readings/recent - Recent sensor data",
    "GET /api/v1/sensors/statistics - Time-series statistics",
    "POST /api/v1/mqtt/publish - Manual MQTT publishing",
    "GET /api/v1/alerts/tenant/{tenantId} - Tenant alerts",
    "GET /api/v1/catalog/data-types - Data type catalog",
    "WebSocket: /ws/greenhouse - STOMP real-time updates",
    "MQTT Topic: GREENHOUSE/{tenantId} - Sensor data ingestion"
  ]
}
